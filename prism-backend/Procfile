web: gunicorn app.main:app -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT --workers 1 --timeout 120 --max-requests 1000 --max-requests-jitter 100
worker: celery -A app.core.celery_app worker --loglevel=info --queues=email,default --concurrency=2
beat: celery -A app.core.celery_app beat --loglevel=info
